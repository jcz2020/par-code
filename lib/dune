(library
 (name par_code)
 (public_name par_code)
 (wrapped false)
 (libraries par par.memory yojson eio eio_main mirage-crypto-rng.unix sqlite3 logs
            cohttp-eio tls-eio digestif uuidm))

(rule
 (targets par_code_version.ml)
 (action
  (with-stdout-to par_code_version.ml
   (bash "cat <<'OCEOF'\n(* Generated by dune from dune-project's (version ...) field. Do not edit. *)\nlet version = \"%{version:par_code}\"\nlet version_info = \"par \" ^ version ^ \" (built on PAR SDK \" ^ Par.Version.version ^ \")\"\nOCEOF"))))
