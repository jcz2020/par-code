opam-version: "2.0"
version: "0.4.5"
synopsis: "Interactive coding agent built on the PAR SDK"
description:
  "par-code is an interactive coding agent (terminal-native coding assistant) built on top of PAR (Programmable Agent Runtime). It drives the full PAR SDK surface - ReAct loop, tool dispatch, type-safe bash, MCP client, skills, workflows, streaming - and doubles as a validation case for the PAR project."
maintainer: ["PAR-Code Contributors"]
authors: ["PAR-Code Contributors"]
license: "Apache-2.0"
tags: ["agents" "llm" "coding" "par" "sdk" "cli"]
