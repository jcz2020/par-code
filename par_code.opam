bug-reports: "https://github.com/jcz2020/par-code/issues"
depends: [
  "ocaml"
  "dune" {>= "3.16" & >= "3.16"}
  "par" {>= "0.7.7"}
  "cmdliner"
  "eio"
  "eio_main"
  "yojson"
  "logs"
  "alcotest"
  "odoc"
  "cohttp-eio"
  "tls-eio"
  "digestif"
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
